<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 
         http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <groupId>fr.moodcraft</groupId>
    <artifactId>EconomyBridgeV2</artifactId>
    <version>2.0</version>
    <packaging>jar</packaging>

    <name>EconomyBridgeV2</name>

    <!-- ⚙️ Java -->
    <properties>
        <java.version>21</java.version>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!-- 📦 REPOS -->
    <repositories>
        <repository>
            <id>papermc</id>
            <url>https://repo.papermc.io/repository/maven-public/</url>
        </repository>

        <repository>
            <id>skriptlang</id>
            <url>https://repo.skriptlang.org/releases</url>
        </repository>
    </repositories>

    <!-- 📚 DEPENDENCIES -->
    <dependencies>

        <!-- Paper -->
        <dependency>
            <groupId>io.papermc.paper</groupId>
            <artifactId>paper-api</artifactId>
            <version>1.20.6-R0.1-SNAPSHOT</version>
            <scope>provided</scope>
        </dependency>

        <!-- QuickShop LOCAL (FIX FINAL) -->
        <dependency>
            <groupId>com.quickshop</groupId>
            <artifactId>quickshop</artifactId>
            <version>6.2.0.11</version>
            <scope>system</scope>
            <systemPath>${project.basedir}/libs/QuickShop.jar</systemPath>
        </dependency>

        <!-- Skript -->
        <dependency>
            <groupId>com.github.SkriptLang</groupId>
            <artifactId>Skript</artifactId>
            <version>2.8.0</version>
            <scope>provided</scope>
        </dependency>

    </dependencies>

    <!-- ⚙️ BUILD -->
    <build>
        <plugins>

            <!-- Java 21 -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <source>21</source>
                    <target>21</target>
                </configuration>
            </plugin>

        </plugins>
    </build>

</project>