<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 
         http://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <!-- 💎 IDENTITÉ DU PLUGIN -->
    <groupId>fr.moodcraft</groupId>
    <artifactId>EconomyBridgeV2</artifactId>
    <version>1.0</version>
    <packaging>jar</packaging>

    <name>EconomyBridgeV2</name>
    <description>Bridge économie dynamique Skript ↔ QuickShop</description>

    <!-- ⚙️ JAVA -->
    <properties>
        <maven.compiler.source>21</maven.compiler.source>
        <maven.compiler.target>21</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    </properties>

    <!-- 📦 REPOSITORIES -->
    <repositories>

        <!-- Paper -->
        <repository>
            <id>papermc</id>
            <url>https://repo.papermc.io/repository/maven-public/</url>
        </repository>

        <!-- GitHub Packages (TES LIBS) -->
        <repository>
            <id>github</id>
            <url>https://maven.pkg.github.com/jeanmarieschintu89-max/EconomyBridgeV2</url>
        </repository>

    </repositories>

    <!-- 📚 DEPENDENCIES -->
    <dependencies>

        <!-- 🧱 Paper API -->
        <dependency>
            <groupId>io.papermc.paper</groupId>
            <artifactId>paper-api</artifactId>
            <version>1.20.4-R0.1-SNAPSHOT</version>
            <scope>provided</scope>
        </dependency>

        <!-- 🧠 Skript -->
        <dependency>
            <groupId>com.skript</groupId>
            <artifactId>skript</artifactId>
            <version>1.0</version>
            <scope>provided</scope>
        </dependency>

        <!-- 📦 QuickShop -->
        <dependency>
            <groupId>com.quickshop</groupId>
            <artifactId>quickshop</artifactId>
            <version>1.0</version>
            <scope>provided</scope>
        </dependency>

    </dependencies>

    <!-- ⚙️ BUILD -->
    <build>

        <finalName>EconomyBridgeV2</finalName>

        <plugins>

            <!-- 🔨 Compiler -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.13.0</version>
                <configuration>
                    <release>17</release>
                </configuration>
            </plugin>

        </plugins>

    </build>

</project>